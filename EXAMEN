//  7. DISEÑOS BASE Y MOTOR GRÁFICO 
function dibujarCompleto(cx, cy, nivel) {
  rectMode(CENTER);
  stroke(40); strokeWeight(2.5); fill(200, 130, 60); rect(cx, cy + 3, anchoComp, altoComp, 22); 
  fill(235, 175, 105); rect(cx, cy, anchoComp, altoComp, 22); 
  noStroke(); fill(170, 110, 50); rect(cx, cy, anchoComp - 15, 16, 5);

  if (nivel >= 1) {
    stroke(40); strokeWeight(2); fill(165, 55, 55); rect(cx, cy, anchoComp + 12, 18, 9);
    fill(195, 75, 75); noStroke(); rect(cx, cy - 2, anchoComp + 6, 6, 3);
  }
  if (nivel >= 2) {
    stroke(40); fill(235, 47, 6);
    rect(cx - 35, cy - 2, 18, 16, 4); rect(cx - 10, cy + 1, 19, 17, 4);
    rect(cx + 15, cy - 3, 17, 15, 4); rect(cx + 40, cy + 2, 18, 16, 4);
  }
  if (nivel >= 3) {
    stroke(40); strokeWeight(2.5); fill(75, 155, 55); rect(cx, cy, anchoComp - 6, 14, 8);
    fill(105, 185, 75); noStroke(); rect(cx, cy - 2, anchoComp - 12, 6, 4); 
  }
}

function dibujarPersonaje(px, py, tipo) {
  stroke(40); strokeWeight(3); 
  if (tipo === 0) fill(52, 152, 219); 
  else if (tipo === 1) fill(155, 89, 182); 
  else fill(45, 52, 54); 
  
  quad(px - 60, py + 80, px + 60, py + 80, px + 45, py + 35, px - 45, py + 35); 
  fill(255); rect(px, py + 60, 45, 40); 
  
  stroke(40); fill(245, 205, 160);
  ellipse(px - 42, py + 5, 14, 20); ellipse(px + 42, py + 5, 14, 20); 
  ellipse(px, py, 85, 90); 

  fill(40); ellipse(px - 18, py - 10, 9, 9); ellipse(px + 18, py - 10, 9, 9); 
  
  stroke(40); strokeWeight(2.5); noFill();
  arc(px, py + 22, 22, 12, 0, PI); 
  
  if (tipo === 0) { 
    fill(74, 50, 28); noStroke(); arc(px, py - 30, 81, 45, PI, 0); 
  } else if (tipo === 1) { 
    fill(220); stroke(40); ellipse(px, py - 45, 35, 35);
  } else { 
    noFill(); stroke(40); strokeWeight(3);
    ellipse(px - 18, py - 10, 22, 22); ellipse(px + 18, py - 10, 22, 22);
    line(px - 7, py - 10, px + 7, py - 10);
  }
}

function calcularResultados() {
  if (tiempoRestante <= 0) return;

  let cantidadTrazos = puntosSalsaX.length;
  let puntosBase = constrain(map(cantidadTrazos, 25, 140, 40, 100), 40, 100);
  
  let aciertosSalsa = 0;
  for (let i = 0; i < nombresSalsaDibujada.length; i++) {
    if (nombresSalsaDibujada[i] === pedidoSalsa) aciertosSalsa++;
  }
  
  let ratioSalsaCorrecta = nombresSalsaDibujada.length > 0 ? aciertosSalsa / nombresSalsaDibujada.length : 0;
  
  if (ratioSalsaCorrecta < 0.6) {
    puntajeFinal = 20;
    comentarioCliente = "¡QUE ES ESTA W#$! Te pedí explícitamente " + pedidoSalsa.toUpperCase() + " y me pusiste lo que quisiste";
    propinaFinal = 0;
    dineroAcumulado -= 300; 
    return;
  }

  textStyle(BOLD);
  puntajeFinal = int(puntosBase);
  let multiplicadorCliente = (tipoCliente === 2) ? 2.5 : 1.0; 

  if (puntajeFinal >= 85) {
    comentarioCliente = "¡La raja! Se nota que usaste el dispensador correcto de " + pedidoSalsa.toUpperCase() + ". Quedó de pana";
    propinaFinal = int(1200 * multiplicadorCliente);
  } else if (puntajeFinal >= 60) {
    comentarioCliente = "Está piola, el " + pedidoSalsa.toUpperCase() + " tiene buen sabor pero pudiste haberle puesto un poco más de empeño al zigzag.";
    propinaFinal = int(500 * multiplicadorCliente);
  } else {
    comentarioCliente = "Bastante cagao con la salsa " + pedidoSalsa.toUpperCase() + ". Está más seco que escupo de momia.";
    propinaFinal = int(100 * multiplicadorCliente);
  }

  dineroAcumulado += propinaFinal + 2000; 
}
// 8. EVENTOS DE CONTROL (SISTEMA) 
function keyPressed() {
  if (key === 'm' || key === 'M') { colorActualSalsa = color(255, 253, 220); tipoSalsaActual = "Mayo"; }
  if (key === 'k' || key === 'K') { colorActualSalsa = color(214, 48, 49); tipoSalsaActual = "Ketchup"; }
  if (key === 'a' || key === 'A') { colorActualSalsa = color(241, 196, 15); tipoSalsaActual = "Mostaza"; }

  if (escena === 2 && completoCaido && key === ' ') { 
    dineroAcumulado -= 500; 
    if (dineroAcumulado < 0) escena = 5; 
    else resetearMesaParaSiguienteCliente(); 
    return; 
  }
  
  if (escena === 2 && ingredienteActual <= 3 && key === ' ') {
    let limiteMin = (tipoCliente === 2) ? 43 : 38;
    let limiteMax = (tipoCliente === 2) ? 57 : 62;
    
    if (tieneMesonAcero) {
      limiteMin -= 15; 
      limiteMax += 15;
    }
    
    if (barraPrecision < limiteMin || barraPrecision > limiteMax) {
      completoCaido = true;
    } else {
      ingredienteActual++;
      barraPrecision = 0; 
    }
  }
}

function mousePressed() {
  if (escena === 0 && dist(mouseX, mouseY, width/2, height-80) < 150) { escena = 1; }
  else if (escena === 1 && dist(mouseX, mouseY, width/2, height-60) < 120) { escena = 2; frameInicialEscena = frameCount; }
  else if (escena === 3 && dist(mouseX, mouseY, width/2, height-60) < 120) { calcularResultados(); escena = 4; }
  
  else if (escena === 4) {
    if (mouseX > width/2 - 220 && mouseX < width/2 - 20 && mouseY > height*0.80 - 22 && mouseY < height*0.80 + 22) {
      if (!tieneMesonAcero && dineroAcumulado >= 1500) { dineroAcumulado -= 1500; tieneMesonAcero = true; }
    }
    else if (mouseX > width/2 + 20 && mouseX < width/2 + 220 && mouseY > height*0.80 - 22 && mouseY < height*0.80 + 22) {
      if (!tieneJunior && dineroAcumulado >= 2000) { dineroAcumulado -= 2000; tieneJunior = true; }
    }
    else if (mouseX > width/2 - 120 && mouseX < width/2 + 120 && mouseY > (height - 35) - 20 && mouseY < (height - 35) + 20) { 
      if (dineroAcumulado >= metaDinero || dineroAcumulado < 0) {
        escena = 5; 
      } else {
        resetearMesaParaSiguienteCliente(); 
      }
    }
  }
  
  else if (escena === 5 && dist(mouseX, mouseY, width/2, height-80) < 120) { 
    dineroAcumulado = 0; 
    tieneJunior = false; 
    tieneMesonAcero = false; 
    resetearMesaParaSiguienteCliente(); 
  }
}

function resetearMesaParaSiguienteCliente() {
  escena = 1; ingredienteActual = 1; completoCaido = false; barraPrecision = 0;
  puntosSalsaX = []; puntosSalsaY = []; nombresSalsaDibujada = []; trazoContinuo = [];
  seleccionarNuevoCliente();
}

function windowResized() { resizeCanvas(windowWidth, windowHeight); }
